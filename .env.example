# --- CONVEX (Shared by Frontend & Python) ---
# Automatically added by `npx convex dev`
CONVEX_DEPLOYMENT=dev:...
NEXT_PUBLIC_CONVEX_URL=https://...
NEXT_PUBLIC_CONVEX_SITE_URL=https://...

# --- AUTH (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- GOOGLE CLOUD / BIGQUERY (Python Worker) ---
GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=EU
GCP_SERVICE_ACCOUNT_JSON={...}
BQ_DATASET_RAW=gdelt_raw
BQ_DATASET_NORM=gdelt_norm
BQ_DATASET_DERIVED=gdelt_derived
BQ_DATASET_SERVING=gdelt_serving
BQ_DATASET_OPS=gdelt_ops

# --- GDELT / WORKER ---
GDELT_MASTERFILE_URL=http://data.gdeltproject.org/gdeltv2/masterfilelist.txt
WORKER_ENV=development
WORKER_POLL_LOOKBACK_MINUTES=180
WORKER_BATCH_SIZE=128

# --- AI & SCRAPING (Python Worker Only) ---
GOOGLE_API_KEY="AIzaSy..."
OPENAI_API_KEY="sk-..."
APIFY_API_TOKEN="apify_api_..."

# --- Railway Specific (Optional, usually for Railway CLI) ---
